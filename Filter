void twofifty(double *pointer)
{
    if(*pointer >255 ){
        *pointer = 255;
    }
    *pointer = round(*pointer);
}
int gxgy(double *gx,double *gy)
{
    //printf("raw input:%f\n",*gx);
    *gx = sqrt(*gx);
    //printf("sqrt gx:%f\n",*gx);
    *gy = sqrt(*gy);
    *gx = *gx + *gy;
    //printf("added:%f\n",*gx);
    twofifty(gx);
    //printf("rounded:%f\n",*gx);
    int temp = *gx;
    return temp;
}
