void grayscale(int height, int width, RGBTRIPLE image[height][width])
{

    for(int ct0 = 0; ct0 < height;ct0++){
        for(int ct1 = 0; ct1 < width;ct1++){
            int red = image[ct0][ct1].rgbtRed;
            int green = image[ct0][ct1].rgbtGreen;
            int blue = image[ct0][ct1].rgbtBlue;
            int average =  round((red + green + blue)/3);
            image[ct0][ct1].rgbtRed = average;
            image[ct0][ct1].rgbtGreen = average;
            image[ct0][ct1].rgbtBlue = average;
        }
    }
    return;
}

